// ERP1 database schema — PostgreSQL.
//
// This file covers the FOUNDATION increment: the security, session, and audit
// model (a clean, modern reimplementation of the legacy Mar-Kov CMS
// Users/Roles/Secured-Items/Response-Levels/E-signature design — see
// docs/SCHEMA_REPORT.md §7). Business-domain tables (Entity, Item, Ordr,
// Lot/Sublot, Inventory, Recipe, etc.) are added in later increments and will
// mirror the legacy schema names for parity.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
  LOCKED
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  username           String?    @unique
  displayName        String
  status             UserStatus @default(ACTIVE)
  passwordHash       String? // Argon2id; null for SSO-only users
  mustChangePassword Boolean    @default(false)
  mfaEnabled         Boolean    @default(false)
  mfaSecret          String? // TOTP secret (encrypted at rest in a later increment)
  ssoSubject         String?    @unique // OIDC subject for SSO users
  lastLoginAt        DateTime?
  failedLoginCount   Int        @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  roles     UserRole[]
  sessions  Session[]
  auditLogs AuditLog[] @relation("AuditActor")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              UserRole[]
  programs           RoleProgram[]
  securedItems       RoleSecuredItem[]
  assignableParents  AssignableRole[]  @relation("ParentRole")
  assignableChildren AssignableRole[]  @relation("ChildRole")

  @@map("roles")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// Delegated administration: which roles a role is permitted to assign.
model AssignableRole {
  id           String @id @default(uuid())
  parentRoleId String
  childRoleId  String
  parentRole   Role   @relation("ParentRole", fields: [parentRoleId], references: [id], onDelete: Cascade)
  childRole    Role   @relation("ChildRole", fields: [childRoleId], references: [id], onDelete: Cascade)

  @@unique([parentRoleId, childRoleId])
  @@map("assignable_roles")
}

// Programs = screens/modules a role may run (legacy RoleProgram/Program).
model Program {
  id        String        @id @default(uuid())
  key       String        @unique // e.g. "inventory.adjust"
  name      String
  folder    String? // menu grouping (legacy Program.Folder)
  createdAt DateTime      @default(now())
  roles     RoleProgram[]

  @@map("programs")
}

model RoleProgram {
  roleId    String
  programId String
  allow     Boolean @default(true)
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@id([roleId, programId])
  @@map("role_programs")
}

// Secured items = granular field/table/action/event controls with response
// levels (reason / signature / witness). Legacy SecuredItem.
model SecuredItem {
  id               String   @id @default(uuid())
  key              String   @unique // stable permission key, e.g. "sublot.disposition"
  dataset          String?
  tableName        String?
  fieldName        String?
  method           String?
  description      String?
  requireReason    Boolean  @default(false)
  requireSignature Boolean  @default(false)
  requireWitness   Boolean  @default(false)
  disabled         Boolean  @default(false)
  securityGroupId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  securityGroup SecurityGroup?    @relation(fields: [securityGroupId], references: [id])
  roles         RoleSecuredItem[]

  @@map("secured_items")
}

model RoleSecuredItem {
  roleId        String
  securedItemId String
  allow         Boolean     @default(false)
  allowWitness  Boolean     @default(false) // may act as witness only
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  securedItem   SecuredItem @relation(fields: [securedItemId], references: [id], onDelete: Cascade)

  @@id([roleId, securedItemId])
  @@map("role_secured_items")
}

// Row-level data segregation tag (legacy SecurityGroup).
model SecurityGroup {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  securedItems SecuredItem[]

  @@map("security_groups")
}

// Server-side session record (also held in Redis). Gives a visible,
// revocable list of active sessions (brief §5).
model Session {
  id         String    @id // session id
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  revokedAt  DateTime?

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Audit trail & electronic signatures (append-only, hash-chained)
// ---------------------------------------------------------------------------

// One row per logged operation (legacy Log). Append-only + tamper-evident:
// `hash` = H(prevHash ‖ canonical(this row)). The app's runtime DB role is
// granted no UPDATE/DELETE on audit tables (enforced in a later migration).
model AuditLog {
  id          BigInt   @id @default(autoincrement())
  at          DateTime @default(now())
  actorUserId String?
  actorLabel  String? // denormalized actor identity at time of action
  action      String // e.g. "user.create"
  program     String?
  workstation String?
  ip          String?
  resultCode  Int      @default(0)
  summary     String?
  prevHash    String?
  hash        String

  actor      User?              @relation("AuditActor", fields: [actorUserId], references: [id])
  changes    AuditFieldChange[]
  signatures ESignature[]

  @@index([at])
  @@index([action])
  @@map("audit_log")
}

// Field-level before/after (legacy LogResult).
model AuditFieldChange {
  id         BigInt   @id @default(autoincrement())
  auditLogId BigInt
  auditLog   AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  tableName  String
  recordId   String?
  fieldName  String
  oldValue   String?
  newValue   String?

  @@index([tableName, recordId])
  @@map("audit_field_change")
}

// Electronic-signature ledger (legacy LogSecuredItem). Captures user + witness
// identities, explanations, signing meaning, and the affected master record.
model ESignature {
  id                 BigInt    @id @default(autoincrement())
  auditLogId         BigInt?
  securedItemKey     String
  meaning            String?
  userId             String
  userLabel          String
  userExplanation    String?
  witnessUserId      String?
  witnessLabel       String?
  witnessExplanation String?
  masterTable        String?
  masterId           String?
  at                 DateTime  @default(now())
  prevHash           String?
  hash               String

  auditLog AuditLog? @relation(fields: [auditLogId], references: [id])

  @@index([masterTable, masterId])
  @@map("esignature")
}

// ===========================================================================
// Master data — mirrors legacy Mar-Kov table/column names (PascalCase via
// @map / @@map) for 1:1 import and tool compatibility. Names/addresses live in
// Address, linked polymorphically through AddressReference. (Modern audit/auth
// tables above intentionally use snake_case; domain tables mirror the legacy.)
// `createdAt`/`updatedAt` are additive (legacy has none) for new-record tracking.
// ===========================================================================

model Entity {
  id             Int      @id @default(autoincrement()) @map("Entity")
  entityCode     String   @unique @map("EntityCode") @db.VarChar(20)
  version        Int?     @map("Version")
  prototype      Boolean? @map("Prototype")
  parentId       Int?     @map("Parent")
  currency       String?  @map("Currency") @db.VarChar(10)
  theirCode      String?  @map("TheirCode") @db.VarChar(20)
  inactive       Boolean? @map("Inactive")
  leadTime       Int?     @map("LeadTime")
  reviewDate     DateTime? @map("ReviewDate")
  shipViaId      Int?     @map("ShipVia")
  terms          String?  @map("Terms") @db.VarChar(20)
  incoterms      String?  @map("Incoterms") @db.VarChar(20)
  isSupplier     Boolean? @map("IsSupplier")
  isManufacturer Boolean? @map("IsManufacturer")
  isSite         Boolean? @map("IsSite")
  isLab          Boolean? @map("IsLab")
  isWarehouse    Boolean? @map("IsWarehouse")
  isShipVia      Boolean? @map("IsShipVia")
  isInstallation Boolean? @map("IsInstallation")
  isCMS          Boolean? @map("IsCMS")
  isShipTo       Boolean? @map("IsShipTo")
  isBillTo       Boolean? @map("IsBillTo")
  isRetain       Boolean? @map("IsRetain")
  isPriceList    Boolean? @map("IsPriceList")
  isSalesman     Boolean? @map("IsSalesman")
  isDivision     Boolean  @default(false) @map("IsDivision")
  salesmanId     Int?     @map("Salesman")
  priceListId    Int?     @map("PriceList")
  territory      String?  @map("Territory") @db.VarChar(20)
  poRequired     Boolean? @map("PoRequired")
  doNotShip      Boolean? @map("DoNotShip")
  sendMsds       Boolean? @map("SendMSDS")
  sendCofA       Boolean? @map("SendCertificateOfAnalysis")
  tax1Group      String?  @map("Tax1Group") @db.VarChar(20)
  tax2Group      String?  @map("Tax2Group") @db.VarChar(20)
  tax3Group      String?  @map("Tax3Group") @db.VarChar(20)
  creditLimit    Decimal? @map("CreditLimit") @db.Money
  group          String?  @map("Group") @db.VarChar(50)
  buyer          String?  @map("Buyer") @db.VarChar(10)
  customerType   String?  @map("CustomerType") @db.VarChar(20)
  language       Int?     @map("Language") @db.SmallInt
  processingType String?  @map("ProcessingType") @db.VarChar(10)
  noBill         Boolean? @map("NoBill")
  context        String   @default("") @map("Context") @db.VarChar(41)
  createdAt      DateTime @default(now()) @map("erp1_created_at")
  updatedAt      DateTime @updatedAt @map("erp1_updated_at")

  @@index([isSupplier])
  @@index([isBillTo])
  @@index([isShipTo])
  @@map("Entity")
}

model Address {
  id               Int      @id @default(autoincrement()) @map("Address")
  name             String   @map("Name") @db.VarChar(255)
  department       String?  @map("Department") @db.VarChar(20)
  addrLine1        String?  @map("AddrLine1") @db.VarChar(255)
  addrLine2        String?  @map("AddrLine2") @db.VarChar(255)
  addrLine3        String?  @map("AddrLine3") @db.VarChar(255)
  city             String?  @map("City") @db.VarChar(255)
  state            String?  @map("State") @db.Char(2)
  zipCode          String?  @map("ZipCode") @db.VarChar(20)
  country          String?  @map("Country") @db.VarChar(2)
  contact          String?  @map("Contact") @db.VarChar(255)
  email            String?  @map("Email") @db.VarChar(100)
  fax              String?  @map("Fax") @db.VarChar(30)
  phone            String?  @map("Phone") @db.VarChar(30)
  stateName        String?  @map("StateName") @db.VarChar(10)
  countryName      String?  @map("CountryName") @db.VarChar(20)
  url              String?  @map("URL") @db.VarChar(1000)
  residential      Boolean? @map("Residential")
  addressCheckSum  Int?     @map("AddressCheckSum")
  emergencyContact String?  @map("EmergencyContact") @db.Text

  @@map("Address")
}

// Polymorphic link: an Address attached to any record (TableName + TableID),
// labelled by Reference (e.g. "Main", "Ship-To", "Bill-To").
model AddressReference {
  address   Int    @map("Address")
  tableId   Int    @map("TableID")
  tableName String @map("TableName") @db.VarChar(128)
  reference String @map("Reference") @db.VarChar(128)

  @@id([address, tableName, tableId, reference])
  @@index([tableName, tableId])
  @@map("AddressReference")
}

model Unit {
  code         String   @id @map("Unit") @db.VarChar(6)
  baseUnit     String?  @map("BaseUnit") @db.VarChar(6)
  baseQty      Float?   @map("BaseQty")
  description  String   @map("Description") @db.VarChar(256)
  version      Int?     @map("Version")
  category     String   @default("") @map("Category") @db.VarChar(6)
  systemUnit   Boolean? @map("SystemUnit")
  showOnScreen Boolean? @map("ShowOnScreen")
  context      String   @default("") @map("Context") @db.VarChar(6)

  @@map("Unit")
}

model Currency {
  code        String  @id @map("Currency") @db.VarChar(10)
  description String? @map("Description") @db.VarChar(256)
  version     Int?    @map("Version")

  @@map("Currency")
}

model Terms {
  code            String  @id @map("Terms") @db.VarChar(20)
  description     String? @map("Description") @db.VarChar(256)
  typeCode        String? @map("TypeCode") @db.VarChar(2)
  basisDateCode   String? @map("BasisDateCode") @db.VarChar(2)
  percent         Float?  @map("Percent")
  discountDaysDue Int?    @map("DiscountDaysDue")
  netDays         Int?    @map("NetDays")

  @@map("Terms")
}

model Item {
  id                    Int      @id @default(autoincrement()) @map("Item")
  itemCode              String   @unique @map("ItemCode") @db.VarChar(30)
  version               Int?     @map("Version")
  prototype             Boolean? @map("Prototype")
  description           String?  @map("Description") @db.VarChar(256)
  altDescription        String?  @map("AltDescription") @db.VarChar(256)
  context               String?  @map("Context") @db.VarChar(32)
  unit                  String?  @map("Unit") @db.VarChar(6)
  pkgTypeId             Int?     @map("PkgType")
  qtyPerPackage         Float?   @map("QtyPerPackage")
  outerTypeId           Int?     @map("OuterType")
  pkgPerOuter           Int?     @map("PkgPerOuter")
  lotRequired           Int?     @map("LotRequired") @db.SmallInt
  replacedById          Int?     @map("ReplacedBy")
  ownerId               Int?     @map("Owner")
  status                String?  @map("Status") @db.VarChar(4)
  retestPeriod          Int?     @map("RetestPeriod")
  maximumLife           Int?     @map("MaximumLife")
  specificGravity       Float?   @map("SpecificGravity")
  noExpiry              Boolean? @map("NoExpiry")
  securityGroup         String?  @map("SecurityGroup") @db.VarChar(20)
  standardCost          Decimal? @map("StandardCost") @db.Money
  standardPurchasePrice Decimal? @map("StandardPurchasePrice") @db.Money
  standardCurrency      String?  @map("StandardCurrency") @db.VarChar(10)
  purchasePrice         Decimal? @map("PurchasePrice") @db.Money
  salesPrice            Decimal? @map("SalesPrice") @db.Money
  targetPrice           Decimal? @map("TargetPrice") @db.Money
  replacementCost       Decimal? @map("ReplacementCost") @db.Money
  supplierId            Int?     @map("Supplier")
  glGroup               String?  @map("GLGroup") @db.VarChar(20)
  abcCode               String?  @map("ABCCode") @db.VarChar(10)
  tax1Group             String?  @map("Tax1Group") @db.VarChar(20)
  isKit                 Boolean? @map("IsKit")
  controlledSubstance   Boolean? @map("ControlledSubstance")
  certifiedOrganic      Boolean? @map("CertifiedOrganic")
  weight                Float?   @map("Weight")
  weightUnit            String?  @map("WeightUnit") @db.VarChar(6)
  serviceGroup          String?  @map("ServiceGroup") @db.VarChar(20)
  service               String?  @map("Service") @db.VarChar(10)
  comment               String?  @map("Comment") @db.Text
  createdAt             DateTime @default(now()) @map("erp1_created_at")
  updatedAt             DateTime @updatedAt @map("erp1_updated_at")

  @@index([context])
  @@index([status])
  @@index([controlledSubstance])
  @@map("Item")
}

// Record of a legacy import/sync run + its reconciliation report (per-table
// source/target counts, inserted/updated/rejected).
model ImportRun {
  id          BigInt    @id @default(autoincrement())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    @default("running") // running | success | failed
  mode        String    @default("full") // full | incremental
  triggeredBy String?
  report      Json?
  error       String?

  @@map("import_run")
}

// ===========================================================================
// Inventory & genealogy (mirrors legacy). Lot -> Sublot -> SublotParent edges
// (many-to-many = blending/splitting) form the trace/recall graph; Inventory is
// the live Sublot x Location x Item x Qty junction; Location is a nestable
// container (InLocation self-ref).
// ===========================================================================

model Lot {
  lot                  String    @id @map("Lot") @db.VarChar(50)
  version              Int?      @map("Version")
  itemId               Int?      @map("Item")
  ordDetailId          Int?      @map("OrdDetail")
  supplierId           Int?      @map("Supplier")
  supLot               String?   @map("SupLot") @db.VarChar(50)
  manufacturerId       Int?      @map("Manufacturer")
  manfLot              String?   @map("ManfLot") @db.VarChar(50)
  manfDate             DateTime? @map("ManfDate")
  destructDate         DateTime? @map("DestructDate")
  receivedDate         DateTime? @map("ReceivedDate")
  cofaDate             DateTime? @map("CofADate")
  reconciliationStatus String?   @map("ReconciliationStatus") @db.VarChar(20)
  comment              String?   @map("Comment") @db.Text
  context              String?   @map("Context") @db.VarChar(32)
  reduceTesting        Boolean?  @map("ReduceTesting")

  @@index([itemId])
  @@index([supplierId])
  @@map("Lot")
}

model Sublot {
  id         Int     @id @default(autoincrement()) @map("Sublot")
  version    Int?    @map("Version")
  releaseId  Int?    @map("Release")
  lot        String? @map("Lot") @db.VarChar(50)
  sublotCode String? @map("SublotCode") @db.VarChar(51)
  context    String? @map("Context") @db.VarChar(32)

  @@index([lot])
  @@map("Sublot")
}

// Genealogy edge: a sublot's parent sublot(s). Many-to-many (blend/split).
model SublotParent {
  sublotId Int @map("Sublot")
  parentId Int @map("Parent")

  @@id([sublotId, parentId])
  @@index([parentId])
  @@map("SublotParent")
}

model Location {
  id            Int       @id @default(autoincrement()) @map("Location")
  locationCode  String?   @map("LocationCode") @db.VarChar(20)
  version       Int?      @map("Version")
  ownerId       Int?      @map("Owner")
  inLocationId  Int?      @map("InLocation")
  context       String?   @map("Context") @db.VarChar(32)
  pkgTypeId     Int?      @map("PkgType")
  ordDetailId   Int?      @map("OrdDetail")
  unopened      Boolean?  @map("Unopened")
  misplacedDate DateTime? @map("MisplacedDate")
  tare          Float?    @map("Tare")
  verifiedDate  DateTime? @map("VerifiedDate")
  status        String?   @map("Status") @db.VarChar(6)
  locationGroup String?   @map("LocationGroup") @db.VarChar(20)
  description   String?   @map("Description") @db.VarChar(256)
  transferCan   Boolean?  @map("TransferCan")
  divisionId    Int?      @map("Division")
  reference     String?   @map("Reference") @db.VarChar(20)

  @@index([inLocationId])
  @@index([status])
  @@index([locationCode])
  @@map("Location")
}

model Inventory {
  id          Int     @id @default(autoincrement()) @map("Inventory")
  sublotId    Int?    @map("Sublot")
  locationId  Int     @map("Location")
  ordDetailId Int?    @map("OrdDetail")
  itemId      Int     @map("Item")
  status      String? @map("Status") @db.VarChar(6)
  qty         Float?  @map("Qty")

  @@index([sublotId])
  @@index([locationId])
  @@index([itemId])
  @@map("Inventory")
}

// ===========================================================================
// Manufacturing recipes (mirrors legacy). Recipe header (Context/OrdSubType
// distinguish batching vs packaging; XML holds the serialized procedure) +
// RecipeDetail lines (ingredients/components/steps).
// ===========================================================================

model Recipe {
  id                Int       @id @default(autoincrement()) @map("Recipe")
  ownerId           Int?      @map("Owner")
  recipeNumber      String?   @map("RecipeNumber") @db.VarChar(20)
  version           Int?      @map("Version")
  comment           String    @default("") @map("Comment") @db.Text
  dateCreated       DateTime? @map("DateCreated")
  imported          Boolean?  @map("Imported")
  mergedNumber      String?   @map("MergedNumber") @db.VarChar(20)
  xml               String?   @map("XML") @db.Text
  context           String?   @map("Context") @db.VarChar(32)
  ordSubType        String?   @map("OrdSubType") @db.VarChar(6)
  isPublished       Boolean?  @map("IsPublished")
  placedBy          String?   @map("PlacedBy") @db.VarChar(255)
  securityGroup     String?   @map("SecurityGroup") @db.VarChar(20)
  formulaOnly       Boolean?  @map("FormulaOnly")
  weightUnit        String?   @map("WeightUnit") @db.VarChar(6)
  inactive          Boolean?  @map("Inactive")
  volumeUnit        String?   @map("VolumeUnit") @db.VarChar(6)
  billToId          Int?      @map("BillTo")
  shared            Boolean?  @map("Shared")
  rework            Boolean?  @map("Rework")
  dateUpdated       DateTime? @map("DateUpdated")
  datePublished     DateTime? @map("DatePublished")
  developmentStatus String?   @map("DevelopmentStatus") @db.VarChar(50)
  leadTime          Int?      @map("LeadTime")
  reference         String?   @map("Reference") @db.VarChar(20)

  @@index([context])
  @@index([recipeNumber])
  @@map("Recipe")
}

model RecipeDetail {
  id                 Int      @id @default(autoincrement()) @map("RecipeDetail")
  recipeId           Int?     @map("Recipe")
  ownerId            Int?     @map("Owner")
  context            String?  @map("Context") @db.VarChar(32)
  parentId           Int?     @map("Parent")
  qualifier          String?  @map("Qualifier") @db.VarChar(40)
  description        String?  @map("Description") @db.VarChar(256)
  itemId             Int?     @map("Item")
  qtyReqd            Float?   @map("QtyReqd")
  line               BigInt?  @map("Line")
  comment            String?  @map("Comment") @db.Text
  execOrder          Int?     @map("ExecOrder")
  mustPreweigh       Int      @default(0) @map("MustPreweigh")
  phase              String?  @map("Phase") @db.VarChar(50)
  batchType          String?  @map("BatchType") @db.VarChar(1)
  manufacturerId     Int?     @map("Manufacturer")
  qtyYield           Float?   @map("QtyYield")
  baseQty            Float?   @map("BaseQty")
  yieldPercent       Float?   @map("YieldPercent")
  pkgTypeId          Int?     @map("PkgType")
  entityUnit         String?  @map("EntityUnit") @db.VarChar(6)
  itemNameId         Int?     @map("ItemName")
  totalWeight        Float?   @map("TotalWeight")
  totalWeightPercent Float?   @map("TotalWeightPercent")
  inactive           Boolean? @map("Inactive")
  percentUnder       Float?   @map("PercentUnder")
  percentOver        Float?   @map("PercentOver")
  tag                String?  @map("Tag") @db.VarChar(20)

  @@index([recipeId])
  @@index([itemId])
  @@map("RecipeDetail")
}

// ===========================================================================
// Orders (mirrors legacy). Ordr is the UNIVERSAL order header — Purchasing
// (Context=PO), Manufacturing batching (MFBA) & packaging (MFPP), and
// Sales/Shipping (SH) are all the same two tables, discriminated by Context.
// OrdDetail is the line item for every order type; Parent (self-ref) + Phase
// model the recipe/BOM hierarchy inside an order. Lot.OrdDetail ties each
// produced/received lot back to the order line that created it — the backbone
// of the derived genealogy (real SublotParent edges are empty in this install).
// Faithful column subset (legacy Ordr has 105 cols, OrdDetail 118); extended to
// full parity per-need.
// ===========================================================================

model Ordr {
  id              Int       @id @default(autoincrement()) @map("Ordr")
  version         Int?      @map("Version")
  context         String?   @map("Context") @db.VarChar(32)
  ownerId         Int?      @map("Owner")
  entityId        Int?      @map("Entity")
  divisionId      Int?      @map("Division")
  shipToId        Int?      @map("ShipTo")
  billToId        Int?      @map("BillTo")
  salesmanId      Int?      @map("Salesman")
  currency        String?   @map("Currency") @db.VarChar(10)
  recipeId        Int?      @map("Recipe")
  status          String?   @map("Status") @db.VarChar(6)
  userHold        String?   @map("UserHold") @db.VarChar(20)
  executionHold   String?   @map("ExecutionHold") @db.VarChar(20)
  creditHold      Boolean?  @map("CreditHold")
  ordSubType      String?   @map("OrdSubType") @db.VarChar(6)
  poNumber        String?   @map("PoNumber") @db.VarChar(25)
  processingType  String?   @map("ProcessingType") @db.VarChar(10)
  isQuote         Boolean?  @map("IsQuote")
  reference       String?   @map("Reference") @db.VarChar(20)
  placedBy        String?   @map("PlacedBy") @db.VarChar(255)
  terms           String?   @map("Terms") @db.VarChar(20)
  securityGroup   String?   @map("SecurityGroup") @db.VarChar(20)
  dateOrdered     DateTime? @map("DateOrdered")
  dateRequired    DateTime? @map("DateRequired")
  dateReleased    DateTime? @map("DateReleased")
  dateStarted     DateTime? @map("DateStarted")
  dateCompleted   DateTime? @map("DateCompleted")
  dateScheduled   DateTime? @map("DateScheduled")
  planStartDate   DateTime? @map("PlanStartDate")
  actualBatchSize Float?    @map("ActualBatchSize")
  manfLot         String?   @map("ManfLot") @db.VarChar(256)
  labourHours     Float?    @map("LabourHours")
  machineHours    Float?    @map("MachineHours")
  parentId        Int?      @map("Parent")
  revision        Int?      @map("Revision")
  comment         String?   @map("Comment") @db.Text
  createdAt       DateTime  @default(now()) @map("erp1_created_at")
  updatedAt       DateTime  @updatedAt @map("erp1_updated_at")

  @@index([context])
  @@index([entityId])
  @@index([status])
  @@index([recipeId])
  @@map("Ordr")
}

model OrdDetail {
  id                    Int       @id @default(autoincrement()) @map("OrdDetail")
  ordrId                Int?      @map("Ordr")
  context               String?   @map("Context") @db.VarChar(32)
  itemId                Int?      @map("Item")
  status                String?   @map("Status") @db.VarChar(6)
  parentId              Int?      @map("Parent")
  ownerId               Int?      @map("Owner")
  qtyReqd               Float?    @map("QtyReqd")
  qtyCommitted          Float?    @map("QtyCommitted")
  qtyUsed               Float?    @map("QtyUsed")
  stdQty                Float?    @map("StdQty")
  qtyYield              Float?    @map("QtyYield")
  baseQty               Float?    @map("BaseQty")
  yieldPercent          Float?    @map("YieldPercent")
  numberOfBatches       Float?    @map("NumberOfBatches")
  line                  BigInt?   @map("Line")
  execOrder             Int?      @map("ExecOrder")
  execSubOrder          Int?      @map("ExecSubOrder")
  sortOrder             Int?      @map("SortOrder")
  phase                 String?   @map("Phase") @db.VarChar(50)
  qualifier             String?   @map("Qualifier") @db.VarChar(40)
  batchType             String?   @map("BatchType") @db.VarChar(1)
  execStatus            String?   @map("ExecStatus") @db.VarChar(6)
  sublotId              Int?      @map("Sublot")
  lot                   String?   @map("Lot") @db.VarChar(50)
  manufacturerId        Int?      @map("Manufacturer")
  pkgTypeId             Int?      @map("PkgType")
  entityUnit            String?   @map("EntityUnit") @db.VarChar(6)
  description           String?   @map("Description") @db.VarChar(256)
  comment               String?   @map("Comment") @db.Text
  mustPreweigh          Int       @default(0) @map("MustPreweigh")
  percentUnder          Float?    @map("PercentUnder")
  percentOver           Float?    @map("PercentOver")
  recipeDetailReference Int?      @map("RecipeDetailReference")
  price                 Decimal?  @map("Price") @db.Money
  datePromised          DateTime? @map("DatePromised")
  dateUpdated           DateTime? @map("DateUpdated")
  reference             String?   @map("Reference") @db.VarChar(20)
  tag                   String?   @map("Tag") @db.VarChar(20)
  isOpen                Boolean?  @map("IsOpen")
  discarded             Boolean?  @map("Discarded")
  inactive              Boolean?  @map("Inactive")
  version               Int?      @map("Version")

  @@index([ordrId])
  @@index([itemId])
  @@index([parentId])
  @@index([sublotId])
  @@index([lot])
  @@map("OrdDetail")
}
