# ============================================================================
# ERP1 environment configuration (EXAMPLE)
# The installer (install.sh) generates a real .env with strong random secrets
# on first install and PRESERVES it on upgrades. Do not commit a real .env.
# ============================================================================

NODE_ENV=production

# --- Web / public-facing (Caddy) ---
HTTP_PORT=80                          # host port Caddy listens on
PUBLIC_URL=http://localhost           # external base URL users browse to

# --- PostgreSQL (runs in a container; data persisted in a named volume) ---
POSTGRES_USER=erp1
POSTGRES_PASSWORD=__generated__       # generated by installer
POSTGRES_DB=erp1
DATABASE_URL=postgresql://erp1:__generated__@db:5432/erp1?schema=public

# --- Redis (sessions + background job queue) ---
REDIS_URL=redis://redis:6379

# --- API ---
API_PORT=3000
SESSION_SECRET=__generated__          # generated by installer
SESSION_TTL_HOURS=12

# --- Bootstrap administrator (FIRST INSTALL ONLY) ---
# On first install the password is chosen as: ERP1_ADMIN_PASSWORD env var, else
# an interactive prompt, else auto-generated. A chosen password is used as-is;
# an auto-generated one forces a change at first login (ADMIN_MUST_CHANGE_PASSWORD).
# Credentials are written to secrets/admin-credentials.txt (root-only).
ADMIN_EMAIL=mcartwright@precisioninkcorp.com
ADMIN_INITIAL_PASSWORD=__generated__
ADMIN_MUST_CHANGE_PASSWORD=true

# --- Legacy Mar-Kov CMS import (READ-ONLY source; configure when ready) ---
# Never grant this account write access. The importer asserts read-only.
LEGACY_MSSQL_HOST=
LEGACY_MSSQL_PORT=1433
LEGACY_MSSQL_DB=CMS
LEGACY_MSSQL_USER=sds_readonly
LEGACY_MSSQL_PASSWORD=
