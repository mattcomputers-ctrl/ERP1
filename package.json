{
  "name": "erp1",
  "version": "0.1.0",
  "private": true,
  "description": "Internal manufacturing/ERP system replacing the legacy Mar-Kov CMS",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @erp1/db generate",
    "db:migrate": "pnpm --filter @erp1/db migrate:deploy",
    "db:seed": "pnpm --filter @erp1/db seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
