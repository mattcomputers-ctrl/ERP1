// ERP1 database schema — PostgreSQL.
//
// This file covers the FOUNDATION increment: the security, session, and audit
// model (a clean, modern reimplementation of the legacy Mar-Kov CMS
// Users/Roles/Secured-Items/Response-Levels/E-signature design — see
// docs/SCHEMA_REPORT.md §7). Business-domain tables (Entity, Item, Ordr,
// Lot/Sublot, Inventory, Recipe, etc.) are added in later increments and will
// mirror the legacy schema names for parity.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & access
// ---------------------------------------------------------------------------

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
  LOCKED
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  username           String?    @unique
  displayName        String
  status             UserStatus @default(ACTIVE)
  passwordHash       String? // Argon2id; null for SSO-only users
  mustChangePassword Boolean    @default(false)
  mfaEnabled         Boolean    @default(false)
  mfaSecret          String? // TOTP secret (encrypted at rest in a later increment)
  ssoSubject         String?    @unique // OIDC subject for SSO users
  lastLoginAt        DateTime?
  failedLoginCount   Int        @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  roles     UserRole[]
  sessions  Session[]
  auditLogs AuditLog[] @relation("AuditActor")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users              UserRole[]
  programs           RoleProgram[]
  securedItems       RoleSecuredItem[]
  assignableParents  AssignableRole[]  @relation("ParentRole")
  assignableChildren AssignableRole[]  @relation("ChildRole")
  approvalPolicy     RoleApprovalPolicy?

  @@map("roles")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// Delegated administration: which roles a role is permitted to assign.
model AssignableRole {
  id           String @id @default(uuid())
  parentRoleId String
  childRoleId  String
  parentRole   Role   @relation("ParentRole", fields: [parentRoleId], references: [id], onDelete: Cascade)
  childRole    Role   @relation("ChildRole", fields: [childRoleId], references: [id], onDelete: Cascade)

  @@unique([parentRoleId, childRoleId])
  @@map("assignable_roles")
}

// Programs = screens/modules a role may run (legacy RoleProgram/Program).
model Program {
  id        String        @id @default(uuid())
  key       String        @unique // e.g. "inventory.adjust"
  name      String
  folder    String? // menu grouping (legacy Program.Folder)
  createdAt DateTime      @default(now())
  roles     RoleProgram[]

  @@map("programs")
}

model RoleProgram {
  roleId    String
  programId String
  allow     Boolean @default(true)
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@id([roleId, programId])
  @@map("role_programs")
}

// Per-user-group (Role) approval policy — which approval capabilities a group
// has. Foundation for the approval / workflow engine: policies are configured
// per group here; enforcement on a specific action (the chosen workflow trigger)
// is wired separately. 1:1 with Role (a role without a row uses the defaults in
// approval-policy.service). The six capabilities mirror the legacy approval model
// (Approval / ApprovalDetail / RoleApprovalDetail) collapsed onto the role.
model RoleApprovalPolicy {
  id                 String   @id @default(uuid())
  roleId             String   @unique
  canRequestApproval Boolean  @default(true) // may submit an action for approval
  canApprove         Boolean  @default(false) // may approve a pending request
  canApproveUpdate   Boolean  @default(false) // may approve an update / edit
  canApproveChange   Boolean  @default(false) // may approve a change (status / disposition)
  canOverride        Boolean  @default(false) // supervisor override / approve-on-behalf
  noApprovalRequired Boolean  @default(false) // this group's own actions are exempt
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  role               Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("role_approval_policy")
}

// Secured items = granular field/table/action/event controls with response
// levels (reason / signature / witness). Legacy SecuredItem.
model SecuredItem {
  id               String   @id @default(uuid())
  key              String   @unique // stable permission key, e.g. "sublot.disposition"
  dataset          String?
  tableName        String?
  fieldName        String?
  method           String?
  description      String?
  requireReason    Boolean  @default(false)
  requireSignature Boolean  @default(false)
  requireWitness   Boolean  @default(false)
  disabled         Boolean  @default(false)
  securityGroupId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  securityGroup SecurityGroup?    @relation(fields: [securityGroupId], references: [id])
  roles         RoleSecuredItem[]

  @@map("secured_items")
}

model RoleSecuredItem {
  roleId        String
  securedItemId String
  allow         Boolean     @default(false)
  allowWitness  Boolean     @default(false) // may act as witness only
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  securedItem   SecuredItem @relation(fields: [securedItemId], references: [id], onDelete: Cascade)

  @@id([roleId, securedItemId])
  @@map("role_secured_items")
}

// Row-level data segregation tag (legacy SecurityGroup).
model SecurityGroup {
  id           String        @id @default(uuid())
  code         String        @unique
  name         String
  securedItems SecuredItem[]

  @@map("security_groups")
}

// Server-side session record (also held in Redis). Gives a visible,
// revocable list of active sessions (brief §5).
model Session {
  id         String    @id // session id
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  revokedAt  DateTime?

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Audit trail & electronic signatures (append-only, hash-chained)
// ---------------------------------------------------------------------------

// One row per logged operation (legacy Log). Append-only + tamper-evident:
// `hash` = H(prevHash ‖ canonical(this row)). The app's runtime DB role is
// granted no UPDATE/DELETE on audit tables (enforced in a later migration).
model AuditLog {
  id          BigInt   @id @default(autoincrement())
  at          DateTime @default(now())
  actorUserId String?
  actorLabel  String? // denormalized actor identity at time of action
  action      String // e.g. "user.create"
  program     String?
  workstation String?
  ip          String?
  resultCode  Int      @default(0)
  summary     String?
  prevHash    String?
  hash        String

  actor      User?              @relation("AuditActor", fields: [actorUserId], references: [id])
  changes    AuditFieldChange[]
  signatures ESignature[]

  @@index([at])
  @@index([action])
  @@map("audit_log")
}

// Field-level before/after (legacy LogResult).
model AuditFieldChange {
  id         BigInt   @id @default(autoincrement())
  auditLogId BigInt
  auditLog   AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)
  tableName  String
  recordId   String?
  fieldName  String
  oldValue   String?
  newValue   String?

  @@index([tableName, recordId])
  @@map("audit_field_change")
}

// Electronic-signature ledger (legacy LogSecuredItem). Captures user + witness
// identities, explanations, signing meaning, and the affected master record.
model ESignature {
  id                 BigInt    @id @default(autoincrement())
  auditLogId         BigInt?
  securedItemKey     String
  meaning            String?
  userId             String
  userLabel          String
  userExplanation    String?
  witnessUserId      String?
  witnessLabel       String?
  witnessExplanation String?
  masterTable        String?
  masterId           String?
  at                 DateTime  @default(now())
  prevHash           String?
  hash               String

  auditLog AuditLog? @relation(fields: [auditLogId], references: [id])

  @@index([masterTable, masterId])
  @@map("esignature")
}

// Application configuration (key/value). Runtime-editable settings (e.g.
// company name, batch-sheet grams threshold). Foundation for the full
// Configuration module; seeded with defaults.
model AppSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("app_settings")
}

// ===========================================================================
// Master data — mirrors legacy Mar-Kov table/column names (PascalCase via
// @map / @@map) for 1:1 import and tool compatibility. Names/addresses live in
// Address, linked polymorphically through AddressReference. (Modern audit/auth
// tables above intentionally use snake_case; domain tables mirror the legacy.)
// `createdAt`/`updatedAt` are additive (legacy has none) for new-record tracking.
// ===========================================================================

model Entity {
  id             Int      @id @default(autoincrement()) @map("Entity")
  entityCode     String   @unique @map("EntityCode") @db.VarChar(20)
  version        Int?     @map("Version")
  prototype      Boolean? @map("Prototype")
  parentId       Int?     @map("Parent")
  currency       String?  @map("Currency") @db.VarChar(10)
  theirCode      String?  @map("TheirCode") @db.VarChar(20)
  inactive       Boolean? @map("Inactive")
  leadTime       Int?     @map("LeadTime")
  reviewDate     DateTime? @map("ReviewDate")
  shipViaId      Int?     @map("ShipVia")
  terms          String?  @map("Terms") @db.VarChar(20)
  incoterms      String?  @map("Incoterms") @db.VarChar(20)
  isSupplier     Boolean? @map("IsSupplier")
  isManufacturer Boolean? @map("IsManufacturer")
  isSite         Boolean? @map("IsSite")
  isLab          Boolean? @map("IsLab")
  isWarehouse    Boolean? @map("IsWarehouse")
  isShipVia      Boolean? @map("IsShipVia")
  isInstallation Boolean? @map("IsInstallation")
  isCMS          Boolean? @map("IsCMS")
  isShipTo       Boolean? @map("IsShipTo")
  isBillTo       Boolean? @map("IsBillTo")
  isRetain       Boolean? @map("IsRetain")
  isPriceList    Boolean? @map("IsPriceList")
  isSalesman     Boolean? @map("IsSalesman")
  isDivision     Boolean  @default(false) @map("IsDivision")
  salesmanId     Int?     @map("Salesman")
  priceListId    Int?     @map("PriceList")
  territory      String?  @map("Territory") @db.VarChar(20)
  poRequired     Boolean? @map("PoRequired")
  doNotShip      Boolean? @map("DoNotShip")
  sendMsds       Boolean? @map("SendMSDS")
  sendCofA       Boolean? @map("SendCertificateOfAnalysis")
  tax1Group      String?  @map("Tax1Group") @db.VarChar(20)
  tax2Group      String?  @map("Tax2Group") @db.VarChar(20)
  tax3Group      String?  @map("Tax3Group") @db.VarChar(20)
  creditLimit    Decimal? @map("CreditLimit") @db.Money
  group          String?  @map("Group") @db.VarChar(50)
  buyer          String?  @map("Buyer") @db.VarChar(10)
  customerType   String?  @map("CustomerType") @db.VarChar(20)
  language       Int?     @map("Language") @db.SmallInt
  processingType String?  @map("ProcessingType") @db.VarChar(10)
  noBill         Boolean? @map("NoBill")
  context        String   @default("") @map("Context") @db.VarChar(41)
  createdAt      DateTime @default(now()) @map("erp1_created_at")
  updatedAt      DateTime @updatedAt @map("erp1_updated_at")

  @@index([isSupplier])
  @@index([isBillTo])
  @@index([isShipTo])
  @@map("Entity")
}

model Address {
  id               Int      @id @default(autoincrement()) @map("Address")
  name             String   @map("Name") @db.VarChar(255)
  department       String?  @map("Department") @db.VarChar(20)
  addrLine1        String?  @map("AddrLine1") @db.VarChar(255)
  addrLine2        String?  @map("AddrLine2") @db.VarChar(255)
  addrLine3        String?  @map("AddrLine3") @db.VarChar(255)
  city             String?  @map("City") @db.VarChar(255)
  state            String?  @map("State") @db.Char(2)
  zipCode          String?  @map("ZipCode") @db.VarChar(20)
  country          String?  @map("Country") @db.VarChar(2)
  contact          String?  @map("Contact") @db.VarChar(255)
  email            String?  @map("Email") @db.VarChar(100)
  fax              String?  @map("Fax") @db.VarChar(30)
  phone            String?  @map("Phone") @db.VarChar(30)
  stateName        String?  @map("StateName") @db.VarChar(10)
  countryName      String?  @map("CountryName") @db.VarChar(20)
  url              String?  @map("URL") @db.VarChar(1000)
  residential      Boolean? @map("Residential")
  addressCheckSum  Int?     @map("AddressCheckSum")
  emergencyContact String?  @map("EmergencyContact") @db.Text

  @@map("Address")
}

// Polymorphic link: an Address attached to any record (TableName + TableID),
// labelled by Reference (e.g. "Main", "Ship-To", "Bill-To").
model AddressReference {
  address   Int    @map("Address")
  tableId   Int    @map("TableID")
  tableName String @map("TableName") @db.VarChar(128)
  reference String @map("Reference") @db.VarChar(128)

  @@id([address, tableName, tableId, reference])
  @@index([tableName, tableId])
  @@map("AddressReference")
}

model Unit {
  code         String   @id @map("Unit") @db.VarChar(6)
  baseUnit     String?  @map("BaseUnit") @db.VarChar(6)
  baseQty      Float?   @map("BaseQty")
  description  String   @map("Description") @db.VarChar(256)
  version      Int?     @map("Version")
  category     String   @default("") @map("Category") @db.VarChar(6)
  systemUnit   Boolean? @map("SystemUnit")
  showOnScreen Boolean? @map("ShowOnScreen")
  context      String   @default("") @map("Context") @db.VarChar(6)

  @@map("Unit")
}

model Currency {
  code        String  @id @map("Currency") @db.VarChar(10)
  description String? @map("Description") @db.VarChar(256)
  version     Int?    @map("Version")

  @@map("Currency")
}

model Terms {
  code            String  @id @map("Terms") @db.VarChar(20)
  description     String? @map("Description") @db.VarChar(256)
  typeCode        String? @map("TypeCode") @db.VarChar(2)
  basisDateCode   String? @map("BasisDateCode") @db.VarChar(2)
  percent         Float?  @map("Percent")
  discountDaysDue Int?    @map("DiscountDaysDue")
  netDays         Int?    @map("NetDays")

  @@map("Terms")
}

// Incoterms / FOB lookup (mirrors legacy). Code -> printable description
// (e.g. "Ship Point" -> "Shipping Point") for the PO document's FOB line.
model IncoTerms {
  code        String  @id @map("IncoTerms") @db.VarChar(20)
  description String? @map("Description") @db.VarChar(256)

  @@map("IncoTerms")
}

model Item {
  id                    Int      @id @default(autoincrement()) @map("Item")
  itemCode              String   @unique @map("ItemCode") @db.VarChar(30)
  version               Int?     @map("Version")
  prototype             Boolean? @map("Prototype")
  description           String?  @map("Description") @db.VarChar(256)
  altDescription        String?  @map("AltDescription") @db.VarChar(256)
  context               String?  @map("Context") @db.VarChar(32)
  unit                  String?  @map("Unit") @db.VarChar(6)
  pkgTypeId             Int?     @map("PkgType")
  qtyPerPackage         Float?   @map("QtyPerPackage")
  outerTypeId           Int?     @map("OuterType")
  pkgPerOuter           Int?     @map("PkgPerOuter")
  lotRequired           Int?     @map("LotRequired") @db.SmallInt
  replacedById          Int?     @map("ReplacedBy")
  ownerId               Int?     @map("Owner")
  status                String?  @map("Status") @db.VarChar(4)
  retestPeriod          Int?     @map("RetestPeriod")
  maximumLife           Int?     @map("MaximumLife")
  specificGravity       Float?   @map("SpecificGravity")
  noExpiry              Boolean? @map("NoExpiry")
  securityGroup         String?  @map("SecurityGroup") @db.VarChar(20)
  standardCost          Decimal? @map("StandardCost") @db.Money
  standardPurchasePrice Decimal? @map("StandardPurchasePrice") @db.Money
  standardCurrency      String?  @map("StandardCurrency") @db.VarChar(10)
  purchasePrice         Decimal? @map("PurchasePrice") @db.Money
  salesPrice            Decimal? @map("SalesPrice") @db.Money
  targetPrice           Decimal? @map("TargetPrice") @db.Money
  replacementCost       Decimal? @map("ReplacementCost") @db.Money
  supplierId            Int?     @map("Supplier")
  glGroup               String?  @map("GLGroup") @db.VarChar(20)
  abcCode               String?  @map("ABCCode") @db.VarChar(10)
  tax1Group             String?  @map("Tax1Group") @db.VarChar(20)
  isKit                 Boolean? @map("IsKit")
  controlledSubstance   Boolean? @map("ControlledSubstance")
  certifiedOrganic      Boolean? @map("CertifiedOrganic")
  weight                Float?   @map("Weight")
  weightUnit            String?  @map("WeightUnit") @db.VarChar(6)
  serviceGroup          String?  @map("ServiceGroup") @db.VarChar(20)
  service               String?  @map("Service") @db.VarChar(10)
  comment               String?  @map("Comment") @db.Text
  // ERP1 lot-tracking flag (not legacy). When true the item is lot-traced
  // (on-hand kept by lot/sublot, recall-capable); when false it is consumed
  // FIFO by quantity. Set by the lot-tracking enabling process; the legacy
  // import never touches it (not in the import mapper).
  lotTracked            Boolean  @default(false) @map("erp1_lot_tracked")
  createdAt             DateTime @default(now()) @map("erp1_created_at")
  updatedAt             DateTime @updatedAt @map("erp1_updated_at")

  @@index([context])
  @@index([status])
  @@index([controlledSubstance])
  @@map("Item")
}

// Record of a legacy import/sync run + its reconciliation report (per-table
// source/target counts, inserted/updated/rejected).
model ImportRun {
  id          BigInt    @id @default(autoincrement())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    @default("running") // running | success | failed
  mode        String    @default("full") // full | incremental
  triggeredBy String?
  report      Json?
  error       String?

  @@map("import_run")
}

// ===========================================================================
// Inventory & genealogy (mirrors legacy). Lot -> Sublot -> SublotParent edges
// (many-to-many = blending/splitting) form the trace/recall graph; Inventory is
// the live Sublot x Location x Item x Qty junction; Location is a nestable
// container (InLocation self-ref).
// ===========================================================================

model Lot {
  lot                  String    @id @map("Lot") @db.VarChar(50)
  version              Int?      @map("Version")
  itemId               Int?      @map("Item")
  ordDetailId          Int?      @map("OrdDetail")
  supplierId           Int?      @map("Supplier")
  supLot               String?   @map("SupLot") @db.VarChar(50)
  manufacturerId       Int?      @map("Manufacturer")
  manfLot              String?   @map("ManfLot") @db.VarChar(50)
  manfDate             DateTime? @map("ManfDate")
  destructDate         DateTime? @map("DestructDate")
  receivedDate         DateTime? @map("ReceivedDate")
  cofaDate             DateTime? @map("CofADate")
  reconciliationStatus String?   @map("ReconciliationStatus") @db.VarChar(20)
  comment              String?   @map("Comment") @db.Text
  context              String?   @map("Context") @db.VarChar(32)
  reduceTesting        Boolean?  @map("ReduceTesting")
  // ERP1 cost-per-unit for this lot (not legacy). Lot-traced items are costed by
  // the consumed lot's unit cost (specific identification); set from the PO line
  // price at receiving and entered per lot at lot-tracking enablement. The legacy
  // import never touches it (not in the import mapper).
  unitCost             Decimal?  @map("erp1_unit_cost") @db.Decimal(18, 6)

  @@index([itemId])
  @@index([supplierId])
  @@map("Lot")
}

model Sublot {
  id         Int     @id @default(autoincrement()) @map("Sublot")
  version    Int?    @map("Version")
  releaseId  Int?    @map("Release")
  lot        String? @map("Lot") @db.VarChar(50)
  sublotCode String? @map("SublotCode") @db.VarChar(51)
  context    String? @map("Context") @db.VarChar(32)

  @@index([lot])
  @@map("Sublot")
}

// Genealogy edge: a sublot's parent sublot(s). Many-to-many (blend/split).
model SublotParent {
  sublotId Int @map("Sublot")
  parentId Int @map("Parent")

  @@id([sublotId, parentId])
  @@index([parentId])
  @@map("SublotParent")
}

model Location {
  id            Int       @id @default(autoincrement()) @map("Location")
  locationCode  String?   @map("LocationCode") @db.VarChar(20)
  version       Int?      @map("Version")
  ownerId       Int?      @map("Owner")
  inLocationId  Int?      @map("InLocation")
  context       String?   @map("Context") @db.VarChar(32)
  pkgTypeId     Int?      @map("PkgType")
  ordDetailId   Int?      @map("OrdDetail")
  unopened      Boolean?  @map("Unopened")
  misplacedDate DateTime? @map("MisplacedDate")
  tare          Float?    @map("Tare")
  verifiedDate  DateTime? @map("VerifiedDate")
  status        String?   @map("Status") @db.VarChar(6)
  locationGroup String?   @map("LocationGroup") @db.VarChar(20)
  description   String?   @map("Description") @db.VarChar(256)
  transferCan   Boolean?  @map("TransferCan")
  divisionId    Int?      @map("Division")
  reference     String?   @map("Reference") @db.VarChar(20)

  @@index([inLocationId])
  @@index([status])
  @@index([locationCode])
  @@map("Location")
}

model Inventory {
  id          Int     @id @default(autoincrement()) @map("Inventory")
  sublotId    Int?    @map("Sublot")
  locationId  Int     @map("Location")
  ordDetailId Int?    @map("OrdDetail")
  itemId      Int     @map("Item")
  status      String? @map("Status") @db.VarChar(6)
  qty         Float?  @map("Qty")

  @@index([sublotId])
  @@index([locationId])
  @@index([itemId])
  @@map("Inventory")
}

// ===========================================================================
// Manufacturing recipes (mirrors legacy). Recipe header (Context RMBA batching
// / RMPP packaging) + RecipeDetail lines. The RecipeDetail rows ARE the
// procedure — a Parent tree with a Context discriminator (BA root, UI
// ingredient, INSTR instruction, PK product, UB use-bulk pointer), interleaved
// by ExecOrder; legacy XML is NULL on every row (verified live).
// Versioning: revisions are sibling rows numbered `BASE.NN` (single active
// published recipe per product); the Version column is an internal save count.
// ===========================================================================

model Recipe {
  id                Int       @id @default(autoincrement()) @map("Recipe")
  ownerId           Int?      @map("Owner")
  recipeNumber      String?   @map("RecipeNumber") @db.VarChar(20)
  version           Int?      @map("Version")
  comment           String    @default("") @map("Comment") @db.Text
  dateCreated       DateTime? @map("DateCreated")
  imported          Boolean?  @map("Imported")
  mergedNumber      String?   @map("MergedNumber") @db.VarChar(20)
  xml               String?   @map("XML") @db.Text
  context           String?   @map("Context") @db.VarChar(32)
  ordSubType        String?   @map("OrdSubType") @db.VarChar(6)
  isPublished       Boolean?  @map("IsPublished")
  placedBy          String?   @map("PlacedBy") @db.VarChar(255)
  securityGroup     String?   @map("SecurityGroup") @db.VarChar(20)
  formulaOnly       Boolean?  @map("FormulaOnly")
  weightUnit        String?   @map("WeightUnit") @db.VarChar(6)
  inactive          Boolean?  @map("Inactive")
  volumeUnit        String?   @map("VolumeUnit") @db.VarChar(6)
  billToId          Int?      @map("BillTo")
  shared            Boolean?  @map("Shared")
  rework            Boolean?  @map("Rework")
  dateUpdated       DateTime? @map("DateUpdated")
  datePublished     DateTime? @map("DatePublished")
  developmentStatus String?   @map("DevelopmentStatus") @db.VarChar(50)
  leadTime          Int?      @map("LeadTime")
  reference         String?   @map("Reference") @db.VarChar(20)

  @@index([context])
  @@index([recipeNumber])
  @@map("Recipe")
}

model RecipeDetail {
  id                 Int      @id @default(autoincrement()) @map("RecipeDetail")
  recipeId           Int?     @map("Recipe")
  ownerId            Int?     @map("Owner")
  context            String?  @map("Context") @db.VarChar(32)
  parentId           Int?     @map("Parent")
  qualifier          String?  @map("Qualifier") @db.VarChar(40)
  description        String?  @map("Description") @db.VarChar(256)
  itemId             Int?     @map("Item")
  qtyReqd            Float?   @map("QtyReqd")
  line               BigInt?  @map("Line")
  comment            String?  @map("Comment") @db.Text
  execOrder          Int?     @map("ExecOrder")
  mustPreweigh       Int      @default(0) @map("MustPreweigh")
  phase              String?  @map("Phase") @db.VarChar(50)
  batchType          String?  @map("BatchType") @db.VarChar(1)
  manufacturerId     Int?     @map("Manufacturer")
  qtyYield           Float?   @map("QtyYield")
  baseQty            Float?   @map("BaseQty")
  yieldPercent       Float?   @map("YieldPercent")
  pkgTypeId          Int?     @map("PkgType")
  entityUnit         String?  @map("EntityUnit") @db.VarChar(6)
  itemNameId         Int?     @map("ItemName")
  totalWeight        Float?   @map("TotalWeight")
  totalWeightPercent Float?   @map("TotalWeightPercent")
  totalVolume        Float?   @map("TotalVolume")
  totalVolumePercent Float?   @map("TotalVolumePercent")
  // Opaque execution pointer on UB ("use bulk") lines — mirrored for a future
  // batch-execution increment; semantics undecoded (see docs/OPEN_QUESTIONS.md).
  useFrom            Int?     @map("UseFrom")
  inactive           Boolean? @map("Inactive")
  percentUnder       Float?   @map("PercentUnder")
  percentOver        Float?   @map("PercentOver")
  tag                String?  @map("Tag") @db.VarChar(20)

  @@index([recipeId])
  @@index([itemId])
  @@map("RecipeDetail")
}

// ===========================================================================
// Orders (mirrors legacy). Ordr is the UNIVERSAL order header — Purchasing
// (Context=PO), Manufacturing batching (MFBA) & packaging (MFPP), and
// Sales/Shipping (SH) are all the same two tables, discriminated by Context.
// OrdDetail is the line item for every order type; Parent (self-ref) + Phase
// model the recipe/BOM hierarchy inside an order. Lot.OrdDetail ties each
// produced/received lot back to the order line that created it — the backbone
// of the derived genealogy (real SublotParent edges are empty in this install).
// Faithful column subset (legacy Ordr has 105 cols, OrdDetail 118); extended to
// full parity per-need.
// ===========================================================================

model Ordr {
  id              Int       @id @default(autoincrement()) @map("Ordr")
  version         Int?      @map("Version")
  context         String?   @map("Context") @db.VarChar(32)
  ownerId         Int?      @map("Owner")
  entityId        Int?      @map("Entity")
  divisionId      Int?      @map("Division")
  shipToId        Int?      @map("ShipTo")
  billToId        Int?      @map("BillTo")
  salesmanId      Int?      @map("Salesman")
  shipViaId       Int?      @map("ShipVia")
  incoterms       String?   @map("Incoterms") @db.VarChar(20)
  currency        String?   @map("Currency") @db.VarChar(10)
  recipeId        Int?      @map("Recipe")
  status          String?   @map("Status") @db.VarChar(6)
  userHold        String?   @map("UserHold") @db.VarChar(20)
  executionHold   String?   @map("ExecutionHold") @db.VarChar(20)
  creditHold      Boolean?  @map("CreditHold")
  ordSubType      String?   @map("OrdSubType") @db.VarChar(6)
  poNumber        String?   @map("PoNumber") @db.VarChar(25)
  processingType  String?   @map("ProcessingType") @db.VarChar(10)
  isQuote         Boolean?  @map("IsQuote")
  reference       String?   @map("Reference") @db.VarChar(20)
  placedBy        String?   @map("PlacedBy") @db.VarChar(255)
  terms           String?   @map("Terms") @db.VarChar(20)
  securityGroup   String?   @map("SecurityGroup") @db.VarChar(20)
  dateOrdered     DateTime? @map("DateOrdered")
  dateRequired    DateTime? @map("DateRequired")
  dateReleased    DateTime? @map("DateReleased")
  dateStarted     DateTime? @map("DateStarted")
  dateCompleted   DateTime? @map("DateCompleted")
  dateScheduled   DateTime? @map("DateScheduled")
  planStartDate   DateTime? @map("PlanStartDate")
  actualBatchSize Float?    @map("ActualBatchSize")
  manfLot         String?   @map("ManfLot") @db.VarChar(256)
  labourHours     Float?    @map("LabourHours")
  machineHours    Float?    @map("MachineHours")
  parentId        Int?      @map("Parent")
  revision        Int?      @map("Revision")
  comment         String?   @map("Comment") @db.Text
  createdAt       DateTime  @default(now()) @map("erp1_created_at")
  updatedAt       DateTime  @updatedAt @map("erp1_updated_at")

  @@index([context])
  @@index([entityId])
  @@index([status])
  @@index([recipeId])
  @@map("Ordr")
}

model OrdDetail {
  id                    Int       @id @default(autoincrement()) @map("OrdDetail")
  ordrId                Int?      @map("Ordr")
  context               String?   @map("Context") @db.VarChar(32)
  itemId                Int?      @map("Item")
  status                String?   @map("Status") @db.VarChar(6)
  parentId              Int?      @map("Parent")
  ownerId               Int?      @map("Owner")
  qtyReqd               Float?    @map("QtyReqd")
  qtyCommitted          Float?    @map("QtyCommitted")
  qtyUsed               Float?    @map("QtyUsed")
  stdQty                Float?    @map("StdQty")
  qtyYield              Float?    @map("QtyYield")
  baseQty               Float?    @map("BaseQty")
  yieldPercent          Float?    @map("YieldPercent")
  numberOfBatches       Float?    @map("NumberOfBatches")
  line                  BigInt?   @map("Line")
  execOrder             Int?      @map("ExecOrder")
  execSubOrder          Int?      @map("ExecSubOrder")
  sortOrder             Int?      @map("SortOrder")
  phase                 String?   @map("Phase") @db.VarChar(50)
  qualifier             String?   @map("Qualifier") @db.VarChar(40)
  batchType             String?   @map("BatchType") @db.VarChar(1)
  execStatus            String?   @map("ExecStatus") @db.VarChar(6)
  sublotId              Int?      @map("Sublot")
  lot                   String?   @map("Lot") @db.VarChar(50)
  manufacturerId        Int?      @map("Manufacturer")
  itemNameId            Int?      @map("ItemName")
  pkgTypeId             Int?      @map("PkgType")
  entityUnit            String?   @map("EntityUnit") @db.VarChar(6)
  description           String?   @map("Description") @db.VarChar(256)
  comment               String?   @map("Comment") @db.Text
  mustPreweigh          Int       @default(0) @map("MustPreweigh")
  percentUnder          Float?    @map("PercentUnder")
  percentOver           Float?    @map("PercentOver")
  recipeDetailReference Int?      @map("RecipeDetailReference")
  price                 Decimal?  @map("Price") @db.Money
  datePromised          DateTime? @map("DatePromised")
  dateUpdated           DateTime? @map("DateUpdated")
  reference             String?   @map("Reference") @db.VarChar(20)
  tag                   String?   @map("Tag") @db.VarChar(20)
  isOpen                Boolean?  @map("IsOpen")
  discarded             Boolean?  @map("Discarded")
  inactive              Boolean?  @map("Inactive")
  version               Int?      @map("Version")

  @@index([ordrId])
  @@index([itemId])
  @@index([parentId])
  @@index([sublotId])
  @@index([lot])
  @@map("OrdDetail")
}

// QC / in-process test spec attached to an order line (mirrors legacy). Powers
// the Quality Control section of the batch sheet: Test + Min/Max/Target/
// Specification -> spec range, with a blank Result for hand-recording.
model OrdDetailTest {
  id            Int     @id @default(autoincrement()) @map("OrdDetailTest")
  ordDetailId   Int?    @map("OrdDetail")
  test          String? @map("Test") @db.VarChar(20)
  qualifier     String? @map("Qualifier") @db.VarChar(40)
  min           Float?  @map("Min")
  max           Float?  @map("Max")
  target        Float?  @map("Target")
  testGroup     String? @map("TestGroup") @db.VarChar(20)
  grade         String? @map("Grade") @db.VarChar(6)
  specification String? @map("Specification") @db.Text
  comment       String? @map("Comment") @db.Text
  line          Int?    @map("Line")
  version       Int?    @map("Version")

  @@index([ordDetailId])
  @@map("OrdDetailTest")
}

// Per-line purchase pricing/packaging (mirrors legacy). For a PO line this
// carries the supplier's packaging: PkgType (an Item whose code is e.g. "DRUM"),
// EntityQuantity (qty per package), EntityUnit (the stock unit), and
// EntityItemCode (the supplier's own item code — the PO's "Your Code"). The
// purchased package count = OrdDetail.QtyReqd / EntityQuantity.
model OrdDetailPricing {
  id             Int      @id @default(autoincrement()) @map("OrdDetailPricing")
  ordDetailId    Int?     @map("OrdDetail")
  pkgTypeId      Int?     @map("PkgType")
  entityItemCode String?  @map("EntityItemCode") @db.VarChar(50)
  entityQuantity Float?   @map("EntityQuantity")
  entityUnit     String?  @map("EntityUnit") @db.VarChar(20)
  qtyPerEntityQty Float?  @map("QtyPerEntityQty")
  priceByPackage Boolean? @map("PriceByPackage")
  version        Int?     @map("Version")

  @@index([ordDetailId])
  @@map("OrdDetailPricing")
}

// Supplier/customer pricing header (mirrors legacy). A price version belongs to an
// Entity (the supplier, for purchase pricing) and is effective-dated; the CURRENT
// version for an entity is the one with the latest EffectiveDate (≤ today). Its
// PriceDetail rows carry the per-item packaging + tiered prices that get copied
// onto a PO line (OrdDetailPricing) when the item is added to that supplier's PO.
model PriceVersion {
  id                  Int       @id @default(autoincrement()) @map("PriceVersion")
  entityId            Int?      @map("Entity")
  effectiveDate       DateTime? @map("EffectiveDate")
  version             Int?      @map("Version")
  comment             String?   @map("Comment") @db.Text
  defaultVerifiedDate DateTime? @map("DefaultVerifiedDate")

  @@index([entityId])
  @@map("PriceVersion")
}

// Per-item pricing line within a PriceVersion (mirrors legacy). Carries the
// supplier packaging (PkgType — an Item whose code is e.g. "DRUM" — EntityQuantity,
// EntityUnit, PriceByPackage), the supplier's own item code (EntityItemCode = the
// PO's "Your Code"), tiered prices by minimum order quantity (MinOrder1/Price1 ..
// MinOrder5/Price5), and lead time. This is where purchasing packaging is
// configured in Mar-Kov; a PO line snapshots the matching row into OrdDetailPricing.
model PriceDetail {
  id             Int      @id @default(autoincrement()) @map("PriceDetail")
  priceVersionId Int?     @map("PriceVersion")
  itemId         Int?     @map("Item")
  entityItemCode String?  @map("EntityItemCode") @db.VarChar(50)
  description    String?  @map("Description") @db.VarChar(256)
  comment        String?  @map("Comment") @db.Text
  currency       String?  @map("Currency") @db.VarChar(10)
  pkgTypeId      Int?     @map("PkgType")
  entityQuantity Float?   @map("EntityQuantity")
  entityUnit     String?  @map("EntityUnit") @db.VarChar(20)
  priceByPackage Boolean? @map("PriceByPackage")
  minOrder1      Float?   @map("MinOrder1")
  price1         Decimal? @map("Price1") @db.Money
  minOrder2      Float?   @map("MinOrder2")
  price2         Decimal? @map("Price2") @db.Money
  minOrder3      Float?   @map("MinOrder3")
  price3         Decimal? @map("Price3") @db.Money
  minOrder4      Float?   @map("MinOrder4")
  price4         Decimal? @map("Price4") @db.Money
  minOrder5      Float?   @map("MinOrder5")
  price5         Decimal? @map("Price5") @db.Money
  leadTime       Int?     @map("LeadTime")
  manufacturerId Int?     @map("Manufacturer")
  version        Int?     @map("Version")
  // The real stock item being priced. `Item` (above) is a NAME alias; `InvItem`
  // is the stockable item (== Item in 15,733/15,745 legacy rows). Sales price
  // resolution keys the stock item off InvItem.
  invItemId      Int?      @map("InvItem")
  verifiedDate   DateTime? @map("VerifiedDate")

  @@index([priceVersionId])
  @@index([itemId])
  @@index([invItemId])
  @@map("PriceDetail")
}

// Item-level testing requirements (mirrors legacy). The QA spec library keyed by
// item: which tests apply on receipt / production / retest, with Min/Max/Target/
// Specification. When a batch order is created from a recipe, the produced
// item's OnProduction tests are copied into OrdDetailTest so the batch ticket's
// Quality Control section is populated (legacy seeds OrdDetailTest from here at
// order creation). Also the future source for §11 LIMS / CofA.
model ItemTest {
  id             Int      @id @default(autoincrement()) @map("ItemTest")
  itemId         Int?     @map("Item")
  test           String?  @map("Test") @db.VarChar(20)
  version        Int?     @map("Version")
  testGroup      String?  @map("TestGroup") @db.VarChar(20)
  qualifier      String?  @map("Qualifier") @db.VarChar(40)
  min            Float?   @map("Min")
  max            Float?   @map("Max")
  target         Float?   @map("Target")
  comment        String?  @map("Comment") @db.Text
  onReceipt      Boolean? @map("OnReceipt")
  onProduction   Boolean? @map("OnProduction")
  onRetest       Boolean? @map("OnRetest")
  grade          String?  @map("Grade") @db.VarChar(6)
  labelClaim     String?  @map("LabelClaim") @db.VarChar(20)
  labelClaimUnit String?  @map("LabelClaimUnit") @db.VarChar(6)
  line           Int?     @map("Line")
  specification  String?  @map("Specification") @db.Text

  @@index([itemId])
  @@map("ItemTest")
}

// Commitment link (mirrors legacy): ties a consumption line (OrdDetail, the
// "use ingredient" UI line) to the source production line it drew from
// (SrcOrdDetail, a "PK" packaged-product line). Resolved through Lot.OrdDetail
// this yields consumed-lot -> produced-lot lineage — the backbone of the
// derived genealogy in this install (SublotParent is empty; the sublot/cost
// linkage columns are unpopulated).
model OrdDetailCommit {
  id             Int      @id @default(autoincrement()) @map("OrdDetailCommit")
  ordDetailId    Int?     @map("OrdDetail")
  srcOrdDetailId Int?     @map("SrcOrdDetail")
  qty            Float?   @map("Qty")
  manufacturerId Int?     @map("Manufacturer")
  packagingReady Boolean? @map("PackagingReady")

  @@index([ordDetailId])
  @@index([srcOrdDetailId])
  @@map("OrdDetailCommit")
}

// Declared item-level composition of a lot (mirrors legacy). Item (not lot)
// granularity — the only provenance available for bulk/WIP lots, whose
// ingredient consumption is recorded item-level, never lot-level, in this
// install. Used as a leaf annotation in trace/recall.
model LotIngredient {
  id      Int    @id @default(autoincrement()) @map("LotIngredient")
  lot     String @map("Lot") @db.VarChar(50)
  itemId  Int    @map("Item")
  percent Float? @map("Percent")

  @@index([lot])
  @@index([itemId])
  @@map("LotIngredient")
}

// ===========================================================================
// Derived genealogy (ERP1, not a legacy mirror — clean snake_case). Directed
// lot-to-lot lineage edge: parentLot was consumed to produce childLot, via a
// packaging order. Recomputed (idempotent) from OrdDetailCommit after each
// import. Recall/trace traverse this graph with recursive CTEs. Real
// SublotParent edges are empty in this install, so this is the live lineage.
// ===========================================================================

model LotGenealogy {
  id        BigInt   @id @default(autoincrement())
  childLot  String   @map("child_lot") @db.VarChar(50)
  parentLot String   @map("parent_lot") @db.VarChar(50)
  viaOrdrId Int?     @map("via_ordr")
  qty       Float?   @map("qty")
  source    String   @default("OrdDetailCommit") @map("source")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([childLot, parentLot, viaOrdrId])
  @@index([childLot])
  @@index([parentLot])
  @@map("lot_genealogy")
}

// Forward shipment-lineage capture (ERP1, not a legacy mirror — clean
// snake_case). Which finished-good lot(s) + quantity shipped on a shipping (SH)
// order, recorded when the order is closed from the hand-written pick list. The
// legacy CMS never recorded this (OrdDetail.Lot/Sublot are null on shipment
// lines — see genealogy-data-reality), so the link is captured going forward.
// This is the lot -> shipment edge recall walks to surface the customer / PO# /
// ship date / quantity that a recalled lot reached. Only meaningful once the
// shipped item is lot-traced. The legacy import never touches this table.
model ShipmentLot {
  id          BigInt   @id @default(autoincrement())
  lot         String   @map("lot") @db.VarChar(50)
  ordrId      Int      @map("ordr") // the SH order the lot shipped on
  ordDetailId Int?     @map("ord_detail") // the SH line fulfilled (optional)
  itemId      Int?     @map("item")
  qty         Float?   @map("qty")
  unit        String?  @map("unit") @db.VarChar(20)
  shippedAt   DateTime @map("shipped_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([lot])
  @@index([ordrId])
  @@map("shipment_lot")
}

// Generic blocking approval request (ERP1, not a legacy mirror). The reusable
// engine for "a request-only group submits an action; a qualified approver
// approves (the domain service then enacts it from the payload) or rejects it."
// `kind` discriminates the action (e.g. order.edit); `payload` is the requested
// change as JSON; `requiredCapability` names the approval policy capability that
// may approve it. Domain services own the enact logic; this table + service own
// the request lifecycle (PENDING -> APPROVED/REJECTED, compare-and-swap). The
// QA-disposition workflow predates this and uses its own table (DispositionApproval);
// it can adopt this engine later. Never imported.
model ApprovalRequest {
  id                 BigInt    @id @default(autoincrement())
  kind               String    @map("kind") @db.VarChar(40)
  targetTable        String    @map("target_table") @db.VarChar(40)
  targetId           String    @map("target_id") @db.VarChar(64)
  payload            String    @map("payload") @db.Text // JSON of the requested change
  requiredCapability String    @map("required_capability") @db.VarChar(40)
  state              String    @default("PENDING") @map("state") @db.VarChar(12)
  requestReason      String?   @map("request_reason")
  requestedById      String    @map("requested_by")
  requestedByLabel   String?   @map("requested_by_label")
  requestedAt        DateTime  @map("requested_at")
  decidedById        String?   @map("decided_by")
  decidedByLabel     String?   @map("decided_by_label")
  decidedAt          DateTime? @map("decided_at")
  decisionReason     String?   @map("decision_reason")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@index([state, kind])
  @@map("approval_request")
}

// DEPRECATED (2026-06-23): QA disposition now rides the shared ApprovalRequest
// engine (kind='release.disposition'; the requested snapshot lives in the request
// payload), exactly like order/PO/SH edits — ReleasesService no longer reads or
// writes this table. Retained in the schema only to avoid a destructive `prisma db
// push` (scripts/migrate.sh runs it WITHOUT --accept-data-loss) on existing installs
// that already have the table; drop it in a future coordinated migration. Never imported.
model DispositionApproval {
  id               BigInt    @id @default(autoincrement())
  releaseId        Int       @map("release")
  state            String    @default("PENDING") @map("state") @db.VarChar(12) // PENDING / APPROVED / REJECTED
  reqStatus        String    @map("req_status") @db.VarChar(8)
  reqGrade         String?   @map("req_grade") @db.VarChar(6)
  reqPurity        Float?    @map("req_purity")
  reqExpiry        DateTime? @map("req_expiry")
  reqReason        String?   @map("req_reason")
  requestedById    String    @map("requested_by")
  requestedByLabel String?   @map("requested_by_label")
  requestedAt      DateTime  @map("requested_at")
  decidedById      String?   @map("decided_by")
  decidedByLabel   String?   @map("decided_by_label")
  decidedAt        DateTime? @map("decided_at")
  decisionReason   String?   @map("decision_reason")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([state])
  @@index([releaseId])
  @@map("disposition_approval")
}

// QA disposition of a sublot (mirrors legacy). The release gate: Status
// (Approved/Hold/Rejected), Grade, Purity, ExpiryDate, ReleasedBy. Linked from
// Sublot.releaseId; surfaced as the QA status on the Lot Trace.
model Release {
  id          Int       @id @default(autoincrement()) @map("Release")
  sampleSetId Int?      @map("SampleSet")
  sublotId    Int?      @map("Sublot")
  status      String?   @map("Status") @db.VarChar(8)
  grade       String?   @map("Grade") @db.VarChar(6)
  purity      Float?    @map("Purity")
  expiryDate  DateTime? @map("ExpiryDate")
  suspend     Boolean?  @map("Suspend")
  releaseDate DateTime? @map("ReleaseDate")
  releasedBy  String?   @map("ReleasedBy") @db.VarChar(255)
  context     String?   @map("Context") @db.VarChar(32)

  @@index([sublotId])
  @@map("Release")
}

// Certificate-of-Analysis header snapshot (mirrors legacy), keyed 1:1 to the
// Release (QA disposition). Holds the product/lot/dates exactly as printed on the
// CofA that ships with a released lot. Test results come from LocationSampleTest
// (joined via Release.SampleSet); specs from the product's ItemTest.
model ReleaseCofA {
  releaseId   Int       @id @map("Release")
  productCode String?   @map("ProductCode") @db.VarChar(30)
  description String?   @map("Description") @db.VarChar(256)
  manfDate    DateTime? @map("ManfDate")
  pkgLot      String?   @map("PkgLot") @db.VarChar(50)
  manfLot     String?   @map("ManfLot") @db.VarChar(50)
  expiryDate  DateTime? @map("ExpiryDate")

  @@index([productCode])
  @@index([manfLot])
  @@map("ReleaseCofA")
}

// Recorded LIMS test result (mirrors legacy). The legacy Result is a sql_variant
// (numeric or free text); stored here as text. Joined to a release's tests via
// SampleSet (= Release.SampleSet). Passed = within spec at test time.
model LocationSampleTest {
  id              Int       @id @default(autoincrement()) @map("LocationSampleTest")
  locationId      Int       @map("Location")
  test            String    @map("Test") @db.VarChar(20)
  qualifier       String?   @map("Qualifier") @db.VarChar(40)
  version         Int?      @map("Version")
  result          String?   @map("Result") @db.Text
  passed          Boolean?  @map("Passed")
  testedTime      DateTime? @map("TestedTime")
  testedBy        String?   @map("TestedBy") @db.VarChar(255)
  approve         Boolean?  @map("Approve")
  comment         String?   @map("Comment") @db.Text
  sampleSetId     Int?      @map("SampleSet")
  testStartedTime DateTime? @map("TestStartedTime")
  notebookRef     String?   @map("NotebookRef") @db.VarChar(256)

  @@index([sampleSetId])
  @@map("LocationSampleTest")
}

// ===========================================================================
// Sales / financial (mirrors legacy). Trans is the financial posting; customer
// INVOICES are Trans with Context='CI' (TransDocument = invoice number). Lines
// in TransDetail. Note: customer is Trans.BillTo (Trans.Entity is null on SH);
// line amount = Qty * Price (no stored extended amount). See sales-docs-mapping.
// ===========================================================================

model Trans {
  id              Int       @id @default(autoincrement()) @map("Trans")
  context         String?   @map("Context") @db.VarChar(6)
  transDocument   String?   @map("TransDocument") @db.VarChar(20)
  documentDate    DateTime? @map("DocumentDate")
  transDate       DateTime? @map("TransDate")
  ordrId          Int?      @map("Ordr")
  billToId        Int?      @map("BillTo")
  ownerId         Int?      @map("Owner")
  salesmanId      Int?      @map("Salesman")
  currency        String?   @map("Currency") @db.VarChar(10)
  currencyRate    Float?    @map("CurrencyRate")
  poNumber        String?   @map("PoNumber") @db.VarChar(25)
  freightCharge   Decimal?  @map("FreightCharge") @db.Money
  tax1Amount      Decimal?  @map("Tax1Amount") @db.Money
  tax2Amount      Decimal?  @map("Tax2Amount") @db.Money
  tax3Amount      Decimal?  @map("Tax3Amount") @db.Money
  reversedTransId Int?      @map("ReversedTrans")

  @@index([ordrId])
  @@index([transDocument])
  @@index([context])
  @@map("Trans")
}

model TransDetail {
  id          Int      @id @default(autoincrement()) @map("TransDetail")
  transId     Int?     @map("Trans")
  context     String?  @map("Context") @db.VarChar(6)
  ordDetailId Int?     @map("OrdDetail")
  itemId      Int?     @map("Item")
  qty         Float?   @map("Qty")
  price       Decimal? @map("Price") @db.Money
  unit        String?  @map("Unit") @db.VarChar(20)

  @@index([transId])
  @@index([ordDetailId])
  @@map("TransDetail")
}

// Supplier AP invoice (mirrors legacy) — the bill a vendor sends for received
// goods. Distinct from CUSTOMER invoices (Trans Context='CI'). Header + BillDetail
// lines that tie back to the PO line (OrdDetail) and the receipt (ChangeSetReceipt).
model Bill {
  id            Int       @id @default(autoincrement()) @map("Bill")
  context       String?   @map("Context") @db.VarChar(12)
  supplierId    Int?      @map("Supplier")
  landingFactor String?   @map("LandingFactor") @db.VarChar(20)
  invoice       String?   @map("Invoice") @db.VarChar(20)
  invoiceDate   DateTime? @map("InvoiceDate") @db.Date
  memo          String?   @map("Memo") @db.Text
  terms         String?   @map("Terms") @db.VarChar(20)
  tax1Group     String?   @map("Tax1Group") @db.VarChar(20)
  tax2Group     String?   @map("Tax2Group") @db.VarChar(20)
  tax3Group     String?   @map("Tax3Group") @db.VarChar(20)
  tax1Amount    Decimal?  @map("Tax1Amount") @db.Money
  tax2Amount    Decimal?  @map("Tax2Amount") @db.Money
  tax3Amount    Decimal?  @map("Tax3Amount") @db.Money
  amount        Decimal?  @map("Amount") @db.Money
  currency      String?   @map("Currency") @db.VarChar(10)
  currencyRate  Float?    @map("CurrencyRate")

  @@index([supplierId])
  @@index([invoice])
  @@map("Bill")
}

model BillDetail {
  id             Int      @id @default(autoincrement()) @map("BillDetail")
  billId         Int?     @map("Bill")
  landingFactor  String?  @map("LandingFactor") @db.VarChar(20)
  receiptId      Int?     @map("Receipt")
  ordDetailId    Int?     @map("OrdDetail")
  amount         Decimal? @map("Amount") @db.Money
  addCost        Decimal? @map("AddCost") @db.Money
  inventoryValue Decimal? @map("InventoryValue") @db.Money
  pending        Boolean? @map("Pending")

  @@index([billId])
  @@index([ordDetailId])
  @@map("BillDetail")
}

// Transaction envelope (mirrors legacy). For shipping, the SH ChangeSet PK is
// the printed PACKING SLIP number; it links the order, the invoice (Trans), and
// (1:1 via ChangeSetShipment) the physical Waybill. See sales-docs-mapping.
model ChangeSet {
  id                 Int       @id @default(autoincrement()) @map("ChangeSet")
  context            String?   @map("Context") @db.VarChar(32)
  ordrId             Int?      @map("Ordr")
  transId            Int?      @map("Trans")
  ownerId            Int?      @map("Owner")
  changeDate         DateTime? @map("ChangeDate")
  poNumber           String?   @map("PoNumber") @db.VarChar(25)
  reverseChangeSetId Int?      @map("ReverseChangeSet")

  @@index([ordrId])
  @@index([transId])
  @@index([context])
  @@map("ChangeSet")
}

// 1:1 bridge ChangeSet -> Waybill (mirrors legacy).
model ChangeSetShipment {
  changeSetId Int  @id @map("ChangeSet")
  waybillId   Int? @map("Waybill")

  @@index([waybillId])
  @@map("ChangeSetShipment")
}

// Physical shipment (mirrors legacy).
model Waybill {
  id            Int       @id @default(autoincrement()) @map("Waybill")
  ownerId       Int?      @map("Owner")
  dateShipped   DateTime? @map("DateShipped")
  status        String?   @map("Status") @db.VarChar(6)
  shipViaId     Int?      @map("ShipVia")
  poNumber      String?   @map("PoNumber") @db.VarChar(25)
  trailerNumber String?   @map("TrailerNumber") @db.VarChar(20)

  @@map("Waybill")
}

// Receipt line (mirrors legacy). 1:1 with its receipt ChangeSet (PK = ChangeSet):
// the legacy model is ONE ChangeSet per received order line. Records the quantity
// received (PSQty) against an order line (OrdDetail) — for a purchase receipt the
// ChangeSet has Context='PO' and ChangeSet.Ordr is the purchase order. Sublot is
// unpopulated in this install (see genealogy-data-reality), so a receipt records
// the event + quantity, not on-hand sublot/lot creation.
model ChangeSetReceipt {
  changeSetId        Int     @id @map("ChangeSet")
  ordDetailId        Int?    @map("OrdDetail")
  itemId             Int?    @map("Item")
  sublotId           Int?    @map("Sublot")
  billToId           Int?    @map("BillTo")
  divisionId         Int?    @map("Division")
  psQty              Float?  @map("PSQty")
  psUnit             String? @map("PSUnit") @db.VarChar(20)
  psQtyEntered       String? @map("PSQtyEntered") @db.VarChar(20)
  qtyPerPsQty        Float?  @map("QtyPerPSQty")
  numberOfContainers Int?    @map("NumberOfContainers")

  @@index([ordDetailId])
  @@map("ChangeSetReceipt")
}
